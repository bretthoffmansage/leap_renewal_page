# Required: server-only Keap / Infusionsoft REST API token.
# Never prefix this with NEXT_PUBLIC_ and never commit real token values.
KEAP_ACCESS_TOKEN=

# Optional: defaults to https://api.infusionsoft.com/crm/rest/v2
KEAP_BASE_URL=https://api.infusionsoft.com/crm/rest/v2

# Optional: defaults to 12000ms
KEAP_REQUEST_TIMEOUT_MS=12000

# Optional: default active LEAP tag ID from the PRD.
KEAP_ACTIVE_LEAPER_TAG_ID=3097

# Optional: raw/debug account visibility is disabled by default and ignored in production.
ENABLE_RAW_KEAP_DEBUG=false
